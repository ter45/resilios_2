# ══════════════════════════════════════════════
#  ResiliOS Cloud — Variables de entorno
#  Copia este archivo como .env y completa los valores
# ══════════════════════════════════════════════

RAILS_ENV=production
SECRET_KEY_BASE=GENERA_CON_rails_secret

# ── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql://resilios:PASSWORD@localhost:5432/resilios_production

# ── Stripe ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Mailer ──────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG....
MAILER_FROM=no-reply@resilios.com

# ── Redis (Sidekiq) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic API (soporte con IA) ──────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Seguridad ───────────────────────────────
NODE_TOKEN_HMAC_SECRET=GENERA_RANDOM_64_CHARS
ALLOWED_HOSTS=app.resilios.com,localhost
