# ══════════════════════════════════════════════
#  ResiliOS Edge — Variables de entorno
#  Copia este archivo como .env y completa los valores
#  NUNCA subas .env al repositorio
# ══════════════════════════════════════════════

# ── Entorno Rails ────────────────────────────
RAILS_ENV=production
SECRET_KEY_BASE=GENERA_CON_rails_secret

# ── Identidad del nodo ───────────────────────
# Generados automáticamente durante el onboarding via QR
RESILIOS_NODE_ID=
RESILIOS_NODE_TOKEN=

# ── Conexión con la nube ─────────────────────
RESILIOS_CLOUD_URL=https://app.resilios.com

# ── Sincronización ──────────────────────────
# Intervalo en segundos entre intentos de sync cuando hay internet
SYNC_INTERVAL_SECONDS=30

# ── Base de datos SQLite ─────────────────────
# Ruta dentro del contenedor (no modificar en producción)
SQLITE_DB_PATH=/app/storage/resilios_edge.sqlite3
